FROM codalab/codalab-legacy:py37

# Keep this image minimal: survival submissions require lifelines + scikit-survival.
# Pins target Python 3.7 compatibility in the legacy runtime.
RUN pip install --no-cache-dir --upgrade "pip<24" "importlib-metadata<7" && \
    pip install --no-cache-dir \
        "lifelines==0.27.8" \
        "scikit-survival==0.17.2"
