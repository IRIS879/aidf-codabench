$backgrounddark = #0c4f96
$backgrounddeep = #0b4a8a
$backgroundmid = #5f88bc
$backgroundlight = #eef4fb
$surfacecard = #ffffff
$surfaceheader = #f4f8fd
$surfaceborder = #d8e5f2
$textcolorlight = #f8fbff
$textcolordark = #18324a
$textmuted = #617589
$aidforange = #f59d27

body
  -webkit-font-smoothing antialiased
  font-family Roboto, sans-serif
  background linear-gradient(180deg, #f5f9ff 0%, #eef4fb 32%, #e8f0fb 100%)
  color $textcolordark !important

#page_content
  margin 0.5em

.segment-container
  padding 0 !important

.segment-container > .header
  font-size 1em !important
  text-align left !important
  margin-top 0 !important
  margin-bottom 0 !important
  background-color $surfaceheader !important
  padding 10px !important
  border-top-left-radius 3px !important
  border-top-right-radius 3px !important
  border-bottom solid 1px $surfaceborder !important

#particles-js, #bg
  background-color $backgrounddeep

.masthead
  background linear-gradient(135deg, #3468b2 0%, #1d4f8f 48%, #0b2e5c 100%)
  border-bottom 1px solid rgba(255,255,255,0.08)
  box-shadow inset 0 -1px 0 rgba(255,255,255,0.05)

.navbar-placeholder
  height 70px

.nav-bar
  background-color $backgrounddark !important
  border-radius 0 !important
  height 70px

  .item:before
    display none

  .item
    color darken($textcolorlight, 20%) !important

    .image
      width 100px !important

  .button-container
    width 100%
    padding 1em

    .ui.button
      color #e2e2e2
      background-color rgba(255, 255, 255, .15)
      font-weight 100

    .ui.button:hover
      color #3f3f3f
      background-color gainsboro

.home-wrap
  display flex
  background-size cover
  background-position 0 70%
  flex-wrap wrap
  min-height auto
  justify-content space-evenly
  width 100%
  max-width 1280px
  margin 0 auto
  padding 1.35rem 0 0

.home-intro-band
  width calc(100% - 3rem)
  margin 0 auto 1.2rem
  padding 2rem 2rem 1.85rem
  display grid
  grid-template-columns minmax(0, 1.2fr) minmax(300px, 0.8fr)
  gap 1.4rem
  align-items stretch
  background radial-gradient(circle at top left, rgba(255,255,255,0.3), transparent 32%), linear-gradient(135deg, #0f2545 0%, #132f56 52%, #183a67 100%)
  border 1px solid rgba(255,255,255,0.08)
  border-radius 28px
  box-shadow 0 28px 54px rgba(10, 34, 68, 0.22)
  color white

  .home-intro-copy
    display flex
    flex-direction column
    justify-content center

  .home-intro-kicker
    margin 0 0 1rem
    color rgba(215, 229, 248, 0.74)
    text-transform uppercase
    letter-spacing 0.16em
    font-size 0.78rem
    font-weight 700

  h1
    margin 0
    max-width 720px
    color white
    font-size 3.1rem
    line-height 1.02
    letter-spacing -0.05em
    font-weight 800

  .home-intro-lead
    max-width 720px
    margin 1.2rem 0 0
    color rgba(228, 236, 248, 0.9)
    font-size 1.08rem
    line-height 1.75

  .home-intro-actions
    display flex
    gap 0.9rem
    margin 1.8rem 0 0
    flex-wrap wrap

    .ui.button
      min-width 170px
      padding 1rem 1.35rem
      border-radius 16px
      font-weight 700
      font-size 1rem

  .home-intro-secondary
    background rgba(255,255,255,0.08) !important
    color white !important
    border 1px solid rgba(255,255,255,0.16) !important
    box-shadow none !important

    &:hover
      background rgba(255,255,255,0.14) !important

  .home-intro-side
    display flex
    flex-direction column
    justify-content space-between
    gap 1rem

  .intro-note-card
    padding 1.35rem 1.4rem
    border-radius 22px
    background linear-gradient(180deg, rgba(255,255,255,0.12), rgba(255,255,255,0.05))
    border 1px solid rgba(255,255,255,0.12)
    backdrop-filter blur(10px)

    p
      margin 0.8rem 0 0
      color rgba(231, 239, 249, 0.84)
      line-height 1.7
      font-size 0.98rem

  .intro-note-label
    display inline-flex
    margin-bottom 0.7rem
    color #9bc2ff
    text-transform uppercase
    letter-spacing 0.12em
    font-size 0.72rem
    font-weight 700

  .intro-note-title
    color white
    font-size 1.35rem
    font-weight 700
    line-height 1.2

  .intro-metric-grid
    display grid
    grid-template-columns repeat(2, minmax(0, 1fr))
    gap 0.8rem
    margin-top 1.1rem

  .intro-metric-card
    display grid
    gap 0.2rem
    padding 0.95rem 0.9rem
    border-radius 18px
    background rgba(255,255,255,0.08)
    border 1px solid rgba(255,255,255,0.1)

    strong
      color white
      font-size 1.55rem
      font-weight 800
      letter-spacing -0.04em

    span
      color rgba(225, 236, 251, 0.8)
      font-size 0.82rem
      text-transform uppercase
      letter-spacing 0.08em
      font-weight 700

  .intro-chip-row
    display flex
    flex-wrap wrap
    gap 0.75rem

    span
      display inline-flex
      align-items center
      padding 0.68rem 0.9rem
      border-radius 999px
      background rgba(255,255,255,0.08)
      border 1px solid rgba(255,255,255,0.12)
      color rgba(236, 242, 250, 0.92)
      font-size 0.88rem
      font-weight 600

  .intro-link-panel
    display grid
    gap 0.85rem

  .intro-link-card
    display grid
    gap 0.45rem
    padding 1rem 1.05rem
    border-radius 20px
    background linear-gradient(180deg, rgba(255,255,255,0.1), rgba(255,255,255,0.06))
    border 1px solid rgba(255,255,255,0.1)
    text-decoration none
    transition transform 0.18s ease, background 0.18s ease, border-color 0.18s ease

    &:hover
      transform translateY(-2px)
      background linear-gradient(180deg, rgba(255,255,255,0.14), rgba(255,255,255,0.08))
      border-color rgba(255,255,255,0.16)

    strong
      color white
      font-size 1.05rem
      font-weight 700
      line-height 1.3

    p
      margin 0
      color rgba(226, 237, 251, 0.82)
      font-size 0.92rem
      line-height 1.6

  .intro-link-card-static
    cursor default

    &:hover
      transform none

  .intro-link-label
    color #9bc2ff
    text-transform uppercase
    letter-spacing 0.12em
    font-size 0.72rem
    font-weight 700

  .segment-container
    margin 2rem 0 !important
    background linear-gradient(180deg, rgba(255,255,255,0.98), rgba(247,250,255,0.95))
    border 1px solid rgba(12, 79, 150, 0.1)
    border-radius 24px
    box-shadow 0 22px 44px rgba(12, 79, 150, 0.09)

  .column-wrap
    width 96.5%
    display flex
    margin 0 0 0

  .vert-wrap
    margin-right 3em
    max-width 770px
    min-width 600px

    .segment-container
      width 100%
      background transparent
      border none
      box-shadow none

    .ui.header
      font-size 24px !important
      background none !important
      border none !important

    .container-content
      padding 1em

  .login-container
    margin-left 1.5em
    max-height 450px !important
    margin-top 7.5em !important

  .login-input
    position relative
    left -15px

.ui.statistic
  flex 1 1 auto
  text-align: center
  width: 100%

  .value
    font-weight 800
    color $backgrounddeep

  .label
    font-weight 100
    color $textmuted

.home-announcement
  width calc(100% - 3rem)
  margin 1.5rem auto 0
  display flex
  align-items flex-start
  gap 1rem
  padding 1rem 1.2rem
  background linear-gradient(135deg, rgba(255,255,255,0.98), rgba(242,247,255,0.95))
  border 1px solid rgba(140, 177, 219, 0.35)
  border-radius 18px
  box-shadow 0 14px 32px rgba(12, 79, 150, 0.08)

  .announcement-badge
    flex 0 0 auto
    display inline-flex
    align-items center
    justify-content center
    padding 0.35rem 0.7rem
    border-radius 999px
    background linear-gradient(135deg, $aidforange, darken($aidforange, 8%))
    color white
    font-size 0.82rem
    font-weight 700
    letter-spacing 0.04em
    text-transform uppercase

  .announcement-copy
    color $textcolordark
    line-height 1.65
    text-align left

    p
      margin 0

.home-hero-panel
  width calc(100% - 3rem)
  margin 0 auto 1rem
  padding 2rem
  display grid
  grid-template-columns minmax(0, 1.3fr) minmax(280px, 0.85fr)
  gap 1.5rem
  align-items stretch
  background radial-gradient(circle at top left, rgba(255,255,255,0.24), transparent 36%), linear-gradient(135deg, #144b8f 0%, #0f3f7b 48%, #0b2f63 100%)
  border 1px solid rgba(255,255,255,0.08)
  border-radius 30px
  box-shadow 0 28px 56px rgba(11, 44, 89, 0.22)
  color white

  .hero-main
    position relative
    z-index 1

  .hero-eyebrow
    margin 0 0 1rem
    color rgba(223, 235, 252, 0.74)
    text-transform uppercase
    letter-spacing 0.16em
    font-size 0.82rem
    font-weight 700

  h1
    margin 0
    max-width 720px
    color white
    font-size 3.25rem
    font-weight 800
    line-height 1.04
    letter-spacing -0.045em

  .hero-lead
    max-width 700px
    margin 1.3rem 0 0
    color rgba(228, 238, 252, 0.9)
    font-size 1.08rem
    line-height 1.75

  .hero-actions
    display flex
    gap 0.95rem
    margin 2rem 0 0
    flex-wrap wrap

    .ui.button
      min-width 172px
      padding 1rem 1.4rem
      border-radius 16px
      font-weight 700
      font-size 1rem

    .hero-secondary-button
      background rgba(255,255,255,0.12) !important
      color white !important
      border 1px solid rgba(255,255,255,0.2) !important
      box-shadow none

      &:hover
        background rgba(255,255,255,0.18) !important

  .hero-tags
    display flex
    gap 0.75rem
    margin 1.4rem 0 0
    flex-wrap wrap

    span
      display inline-flex
      align-items center
      padding 0.55rem 0.85rem
      border-radius 999px
      background rgba(255,255,255,0.12)
      border 1px solid rgba(255,255,255,0.12)
      color rgba(236, 243, 252, 0.92)
      font-size 0.9rem

  .hero-side
    display flex
    flex-direction column
    gap 1rem

  .hero-side-card
    background linear-gradient(180deg, rgba(255,255,255,0.12), rgba(255,255,255,0.06))
    border 1px solid rgba(255,255,255,0.12)
    border-radius 22px
    padding 1.2rem 1.25rem
    backdrop-filter blur(8px)

  .spotlight-label
    margin 0 0 1rem
    color rgba(224, 236, 252, 0.7)
    text-transform uppercase
    letter-spacing 0.08em
    font-size 0.78rem
    font-weight 700

  .spotlight-metrics
    display grid
    gap 0.8rem

  .metric-item
    display flex
    justify-content space-between
    align-items baseline
    gap 1rem
    padding-bottom 0.8rem
    border-bottom 1px solid rgba(255,255,255,0.08)

    &:last-child
      padding-bottom 0
      border-bottom none

  .metric-value
    font-size 1.75rem
    font-weight 800
    letter-spacing -0.03em

  .metric-label
    color rgba(229, 239, 252, 0.86)
    font-size 0.95rem

  .quick-notes
    display grid
    gap 0.9rem

  .note-row
    display grid
    gap 0.3rem

  .note-title
    color #9bc2ff
    font-size 0.8rem
    font-weight 700
    letter-spacing 0.08em
    text-transform uppercase

  .note-text
    color rgba(235, 243, 252, 0.9)
    line-height 1.6

.stats-band
  width calc(100% - 3rem) !important
  margin 2rem auto 0 !important
  display grid
  grid-template-columns minmax(0, 0.9fr) minmax(0, 1.1fr)
  gap 1.6rem
  align-items stretch
  padding 2rem !important
  background linear-gradient(135deg, rgba(12,79,150,0.98), rgba(18,67,126,0.98) 52%, rgba(8,46,92,0.98)) !important
  border-radius 28px
  border 1px solid rgba(255,255,255,0.08)
  box-shadow 0 24px 50px rgba(11, 44, 89, 0.2)

  .stats-band-intro
    text-align left
    color white

    .band-label
      margin 0 0 0.9rem
      text-transform uppercase
      letter-spacing 0.12em
      font-size 0.8rem
      font-weight 700
      color rgba(208, 225, 248, 0.72)

    h2
      margin 0
      color white
      font-size 2rem
      line-height 1.1

    p
      margin 1rem 0 0
      color rgba(226, 236, 249, 0.86)
      line-height 1.75

  .stats-band-grid
    display grid
    grid-template-columns repeat(3, minmax(0, 1fr))
    gap 1rem

  .band-stat-card
    padding 1.4rem 1.1rem
    border-radius 20px
    background linear-gradient(180deg, rgba(255,255,255,0.12), rgba(255,255,255,0.08))
    border 1px solid rgba(255,255,255,0.1)
    box-shadow inset 0 1px 0 rgba(255,255,255,0.08)

    .value
      color white
      font-size 2.3rem
      font-weight 800
      letter-spacing -0.04em

    .label
      margin-top 0.45rem
      color rgba(220, 232, 247, 0.86)
      font-size 0.92rem
      font-weight 500

.github.button
  background-color #6e5494 !important

.github.button:hover
  background-color #523e6e !important

.chahub.button
  background-color #405e73 !important

.chahub.button:hover
  background-color $backgrounddark !important

/* Login Card */
.container-content
  text-align center
  padding 2em 4em
  color $textmuted

  p
    margin 0.75em

  form input
    background transparent !important
    border-top none
    border-right none
    border-left none
    width 60%
    font-size 20px
    margin-left -38px
    line-height 1.2
    padding 0 5px 0 38px
    height 45px


  .focus_input
    font-size 20px
    margin 0 auto
    line-height 1.2
    padding 0 0 0 38px
    height 45px


  iframe
    box-shadow 1px 1px 3px grey

  form input:hover
    background transparent !important
    border-top none
    border-right none
    border-bottom 2px solid $backgrounddark
    border-left none
    width 60%
    font-size 20px

  form input:focus
    outline none
    border-bottom 2px solid $backgrounddark


  #login_form a
    color #858585


  #login_form a:hover
    font-weight bold !important


  #login_form a:focus
    font-weight bold !important


  form p a:focus
    text-decoration underline !important


  .input_coloring
    -webkit-box-shadow 0 0 0 30px white inset


  #outline
    text-align center
    display inline-grid
    margin 1em
    grid-gap 0.5em

#action-container
  width calc(100% - 3rem)
  margin 2rem auto 0 !important

  .container-content
    display flex
    gap 1.5rem

  .column
    flex 1
    background linear-gradient(180deg, rgba(255,255,255,1), rgba(244,249,255,0.98) 50%, rgba(235,244,255,0.96))
    border 1px solid rgba(12, 79, 150, 0.12)
    border-radius 24px
    padding 1.8rem 1.3rem
    box-shadow inset 0 1px 0 rgba(255,255,255,0.95), 0 18px 36px rgba(12,79,150,0.08)
    transition transform 0.18s ease, box-shadow 0.18s ease

    &:hover
      transform translateY(-4px)
      box-shadow inset 0 1px 0 rgba(255,255,255,0.95), 0 22px 40px rgba(12,79,150,0.12)

  .icon
    color $aidforange

  h3.ui.header
    color $backgrounddeep !important

  .column p
    color $textmuted

#about-container
  width calc(100% - 3rem)
  margin 2rem auto 3rem !important
  max-width none

  p
    text-align justify !important

  .container-content
    display flex
    padding 2rem 2.2rem


  .color-header
    color $textcolordark

  .workflow-track
    width 100%
    display grid
    grid-template-columns repeat(3, minmax(0, 1fr))
    gap 1.2rem

  .workflow-step
    position relative
    padding 1.5rem
    border-radius 22px
    border 1px solid rgba(12, 79, 150, 0.1)
    background linear-gradient(180deg, rgba(255,255,255,1), rgba(243,248,255,0.96))
    box-shadow 0 16px 34px rgba(8, 53, 101, 0.08)
    text-align left

  .workflow-index
    display inline-flex
    align-items center
    justify-content center
    width 48px
    height 48px
    border-radius 14px
    margin-bottom 1rem
    background linear-gradient(135deg, rgba(12,79,150,0.1), rgba(245,157,39,0.16))
    color $backgrounddeep
    font-weight 800
    letter-spacing -0.03em

  .workflow-title
    color $backgrounddeep
    font-size 1.15rem
    font-weight 700

  .workflow-copy
    margin-top 0.7rem
    color $textmuted
    line-height 1.7

@media only screen and (max-width: 1100px)
  .home-intro-band
    grid-template-columns 1fr

    h1
      font-size 2.55rem

    .intro-metric-grid
      grid-template-columns repeat(2, minmax(0, 1fr))

  .home-hero-panel
    grid-template-columns 1fr

  .stats-band
    grid-template-columns 1fr

    .stats-band-grid
      grid-template-columns repeat(3, minmax(0, 1fr))

@media only screen and (max-width: 900px)
  .home-announcement,
  .home-intro-band,
  .home-hero-panel,
  .stats-band,
  #action-container,
  #about-container
    width calc(100% - 1.5rem) !important

  .home-intro-band
    padding 1.35rem

    h1
      font-size 2.1rem

    .home-intro-actions
      flex-direction column

      .ui.button
        width 100%

    .intro-metric-grid
      grid-template-columns 1fr

  .home-hero-panel
    padding 1.4rem

    h1
      font-size 2.4rem

  .stats-band .stats-band-grid
    grid-template-columns 1fr

  #action-container .container-content
    flex-direction column

  #about-container .workflow-track
    grid-template-columns 1fr

.news
  margin-bottom 5em
  clear both

.news-heading
  float left

.news-heading-title
  color darkslategray


.news-date
  float right
  color darkslategray

.news-body
  float left 
  clear left
  text-align left

#cite-container
  padding 2em
  align-items left
  
#cite-container .row
  margin 2em
  padding 1em !important
  background-color #F8F9FA

#cite-container pre
  text-align left

.footer.segment
  padding 2em
  margin 1em 7.5em
  background linear-gradient(135deg, rgba(97, 129, 178, 0.99), rgba(42, 86, 147, 0.99) 52%, rgba(8, 61, 118, 1)) !important
  border-radius 18px

.logged-in
  display flex
  justify-content center
  width 100%
  max-width 100% !important
  min-width 100%
  margin -3em 0 0 0 !important

  .segment-container
    margin 3em 1.5em !important

  .tile-wrapper
    min-width 520px !important

    .container-content
      padding 1em
      display flex
      flex-direction column
      justify-content flex-end

.loader-container
  display flex
  align-items center
  justify-content center
  width 510px
  height 250px


.lds-ring
  display inline-block
  position relative
  width 64px
  height 64px

.lds-ring div
  box-sizing border-box
  display block
  position absolute
  width 51px
  height 51px
  margin 6px
  border 6px solid #06649e
  border-radius 50%
  animation lds-ring 1.2s cubic-bezier(0.5, 0, 0.5, 1) infinite
  border-color #06649e transparent transparent transparent

.lds-ring div:nth-child(1)
  animation-delay -0.45s

.lds-ring div:nth-child(2)
  animation-delay -0.3s

.lds-ring div:nth-child(3)
  animation-delay -0.15s

@keyframes lds-ring
  0% {
    transform: rotate(0deg)
  }
  100% {
    transform: rotate(360deg)
  }


.partner-img
  width 140px
  height 140px
  object-fit contain

#partners-row1
  padding-bottom 0px

front-page-competitions
  width 100%
